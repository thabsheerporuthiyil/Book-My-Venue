```env
# =========================
# PROJECT
# =========================
PROJECT_NAME=Book My Venue
ENVIRONMENT=development
DEBUG=True

# =========================
# API GATEWAY
# =========================
GATEWAY_PORT=8080

# =========================
# AUTH SERVICE
# =========================
AUTH_SERVICE_PORT=8001
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
JWT_SECRET_KEY=change-this-secret-key

# =========================
# VENUE SERVICE
# =========================
VENUE_SERVICE_PORT=8002
VENUE_DB_NAME=venue_db
VENUE_DB_USER=venue_user
VENUE_DB_PASSWORD=venue_password
VENUE_DB_HOST=venue-db
VENUE_DB_PORT=5432

# =========================
# BOOKING SERVICE
# =========================
BOOKING_SERVICE_PORT=8003
BOOKING_DB_NAME=booking_db
BOOKING_DB_USER=booking_user
BOOKING_DB_PASSWORD=booking_password
BOOKING_DB_HOST=booking-db
BOOKING_DB_PORT=5432

# =========================
# NOTIFICATION SERVICE
# =========================
NOTIFICATION_SERVICE_PORT=8004
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_password
NOTIFICATION_DB_HOST=notification-db
NOTIFICATION_DB_PORT=5432

# =========================
# AI SERVICE
# =========================
AI_SERVICE_PORT=8005
AI_DB_NAME=ai_db
AI_DB_USER=ai_user
AI_DB_PASSWORD=ai_password
AI_DB_HOST=ai-db
AI_DB_PORT=5432

# =========================
# REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379

# =========================
# SERVICE SECURITY
# =========================
INTERNAL_SERVICE_API_KEY=change-this-internal-api-key

# =========================
# CLOUD STORAGE
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =========================
# AI / LLM
# =========================
OPENAI_API_KEY=
GEMINI_API_KEY=